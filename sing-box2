        "outbound": "📲 TG"
      },
      {
        "rule_set": "geosite-openai",
        "outbound": "🤖 AI"
      },
      {
        "inbound": "mixed-in",
        "action": "resolve"
      },
      {
        "rule_set": [
          "geoip-cn"
        ],
        "outbound": "DIRECT"
      },
      {
        "rule_set": [
          "geoip-telegram"
        ],
        "outbound": "📲 TG"
      }
    ],
    "rule_set": [
      {
