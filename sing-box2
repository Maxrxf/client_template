        "type": "h3",
        "tag": "Remote",
        "detour": "GLOBAL",
        "domain_resolver": "Hosts",
        "server": "cloudflare-dns.com"
      },
      {
        "type": "h3",
        "tag": "Local",
        "domain_resolver": "Hosts",
        "server": "dns.alidns.com"
      },
      {
        "type": "hosts",
        "tag": "Hosts",
        "predefined": {
          "dns.alidns.com": [
            "223.5.5.5",
            "223.6.6.6",
            "2400:3200::1",
            "2400:3200:baba::1"
