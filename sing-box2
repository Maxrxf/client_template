        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Global",
        "server": "Remote"
      },
      {
        "clash_mode": "Direct",
        "server": "Local"
      },
      {
        "query_type": [
          "HTTPS",
          "SVCB"
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-category-ads-all",
          "geosite-openai@ads"
        ],
        "action": "reject"
      },
      {
        "rule_set": "geosite-geolocation-cn",
        "server": "Local"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geosite-geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "geoip-cn"
          }
        ],
        "server": "Remote"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "Fakeip",
        "rewrite_ttl": 1
      }
    ],
    "strategy": "prefer_ipv6",
    "independent_cache": true,
    "client_subnet": "202.96.0.0/11"
  },
  "ntp": {
    "enabled": true,
    "server": "time.apple.com",
    "server_port": 123
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.18.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 2080
        }
      }
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "DIRECT"
    },
    "<INBOUND_REPLACE>",
    {
      "type": "selector",
      "tag": "GLOBAL",
      "outbounds": [
        "DIRECT",
        "♻️ AUTO",
        "<NODE_REPLACE>"
      ],
      "default": "♻️ AUTO"
    },
    {
      "type": "urltest",
      "tag": "♻️ AUTO",
      "outbounds": [
        "<NODE_REPLACE>"
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "5m0s",
      "tolerance": 50
    },
    {
      "type": "selector",
      "tag": "📲 TG",
      "outbounds": [
        "GLOBAL",
        "<NODE_REPLACE>"
      ]
    },
    {
      "type": "selector",
      "tag": "🤖 AI",
      "outbounds": [
        "GLOBAL",
        "<NODE_REPLACE>"
      ]
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "DIRECT"
      },
      {
        "clash_mode": "Global",
        "outbound": "GLOBAL"
      },
      {
        "clash_mode": "Direct",
        "outbound": "DIRECT"
      },
      {
        "protocol": "bittorrent",
        "outbound": "DIRECT"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 853
          },
          {
            "network": "udp",
            "port": 443
          },
          {
            "protocol": "stun"
          },
          {
            "rule_set": [
              "geosite-category-ads-all",
              "geosite-openai@ads"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "domain": "services.googleapis.cn",
        "outbound": "GLOBAL"
      },
      {
        "rule_set": [
          "geosite-geolocation-cn",
          "geosite-microsoft@cn",
          "geosite-private",
